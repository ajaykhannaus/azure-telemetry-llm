# Grafana image — datasource provisioning only.
# Dashboards are imported via API by scripts/fix-grafana-datasources.sh
# (file provisioning was overwriting API fixes every 30s and shipped invalid
# fieldConfig.color.mode values that crash Grafana 11).
FROM grafana/grafana:11.3.0

COPY dashboards/provisioning/datasources.yaml \
     /etc/grafana/provisioning/datasources/datasources.yaml

ENV GF_PATHS_PROVISIONING=/etc/grafana/provisioning \
    GF_USERS_DEFAULT_THEME=light \
    PROMETHEUS_URL=http://prometheus:9090 \
    LOKI_URL=http://loki:3100 \
    TEMPO_URL=http://tempo:3200

EXPOSE 3000
