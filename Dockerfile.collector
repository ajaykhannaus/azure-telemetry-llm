# OpenTelemetry Collector image — Bucket 1.
# Uses the upstream contrib distribution so the tail_sampling, loki, and
# prometheusremotewrite exporters are available out of the box.
FROM otel/opentelemetry-collector-contrib:0.111.0

COPY infra/otel-collector-azure-config.yaml /etc/otelcol-contrib/config.yaml
COPY azure/otel-collector-entrypoint.sh /otel-collector-entrypoint.sh

USER root
RUN chmod +x /otel-collector-entrypoint.sh
USER 10001

EXPOSE 4317 4318 8888 13133

ENTRYPOINT ["/otel-collector-entrypoint.sh"]
