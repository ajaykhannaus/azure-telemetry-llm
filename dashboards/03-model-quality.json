el=All&var-operation=All&var-status=All&var-data_class=All&var-environment=dev\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">5. User</a><a href=\"/d/ai-telemetry-cost?var-department=All&var-region=All&var-provider=All&var-model=All&var-operation=All&var-status=All&var-data_class=All&var-environment=dev\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">6. Cost & Usage</a><a href=\"/d/ai-telemetry-safety?var-department=All&var-region=All&var-provider=All&var-model=All&var-operation=All&var-status=All&var-data_class=All&var-environment=dev\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">7. Safety & Security</a></div>",
