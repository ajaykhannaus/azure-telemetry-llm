    {
      "id": 2,
      "type": "stat",
      "title": "Hallucination rate",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "percentChangeColorMode": "standard",
        "text": {}
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "(sum(count_over_time({service_name=~\".+\"} | json | event_type=\"eval_result\" | department=~\"$department\" | model_provider=~\"$provider\" | model_name=~\"$model\" | operation_name=~\"$operation\" | faithfulness < 5 [1h])) / (sum(count_over_time({service_name=~\".+\"} | json | event_type=\"eval_result\" | department=~\"$department\" | model_provider=~\"$provider\" | model_name=~\"$model\" | operation_name=~\"$operation\" [1h])) or on() vector(1))) * 100",
          "refId": "A",
          "queryType": "instant",
          "instant": true,
          "range": false
        }
      ],
      "description": "% of judged responses where `faithfulness < 5` (0\u201310 judge scale). Source: Loki `eval_result` events (~sampled traffic). Requires evaluator enabled."
    },
    {
