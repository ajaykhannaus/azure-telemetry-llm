    {
      "id": 2,
      "type": "row",
      "title": "Login & user growth",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Logins (24h)",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "sum(count_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"login_event\" | tenant_id=~\"$tenant\" [24h])) or vector(0)",
          "refId": "A",
          "queryType": "range",
          "instant": false,
          "range": true
        }
      ],
      "description": "Count of `login_event` logs in 24h \u2014 emitted when a new session starts (turn 1)."
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active users (24h)",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "count(sum by (user_id) (count_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" [24h])))",
          "refId": "A",
          "queryType": "range",
          "instant": false,
          "range": true
        }
      ],
      "description": "Distinct `user_id` values with at least one `telemetry_event` in 24h."
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Monthly active users (30d)",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
