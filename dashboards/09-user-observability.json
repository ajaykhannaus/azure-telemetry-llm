      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "count(sum by (user_id) (count_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"login_event\" | tenant_id=~\"$tenant\" [30d])))",
          "refId": "A",
          "queryType": "range",
          "instant": false,
          "range": true
        }
      ],
      "description": "Distinct users with a `login_event` in the last 30 days \u2014 monthly active user (MAU) proxy."
