{
  "uid": "ai-telemetry-users",
  "title": "9. User-Level Observability",
  "description": "Login tracking, monthly user growth, top token consumers, session time, and sudden LLM usage spikes.",
  "tags": [
    "ai-telemetry",
    "users",
    "sessions",
    "login"
  ],
  "schemaVersion": 39,
  "version": 1,
  "style": "light",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "tenant",
        "label": "Tenant",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, tenant_id)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "model",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, model_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "environment",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, environment)",
        "multi": false,
        "includeAll": false,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "dev",
          "value": "dev"
        },
        "sort": 1
      }
    ]
  },
