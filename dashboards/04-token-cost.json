      },
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(increase(ai_gateway_request_cost_USD_total{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",environment=~\"$environment\"}[5m])) / clamp_min(sum(increase(ai_gateway_request_count_total{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",environment=~\"$environment\"}[5m])), 1e-9)",
          "legendFormat": "Avg cost / request",
          "refId": "A",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "Average cost per request over time \u2014 `increase(cost) / increase(requests)` from Prometheus (Loki per-user ratios exceed local query resolution limits in range mode)."
    },
