    {
      "id": 3,
      "type": "timeseries",
      "title": "Cost per request",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "showPoints": "never",
            "pointSize": 5,
            "axisColorMode": "text",
            "axisBorderShow": false,
            "axisGridShow": true,
            "lineStyle": {
              "fill": "solid"
            },
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg(avg_over_time({service_name=~\".+\"} | json | event_type=\"telemetry_event\" | department=~\"$department\" | region=~\"$region\" | model_provider=~\"$provider\" | model_name=~\"$model\" | unwrap cost_usd [5m]))",
          "legendFormat": "Avg cost / request",
          "refId": "A",
          "queryType": "range"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | event_type=\"telemetry_event\" | department=~\"$department\" | region=~\"$region\" | model_provider=~\"$provider\" | model_name=~\"$model\" | unwrap cost_usd [5m]))",
          "legendFormat": "{{model_name}}",
          "refId": "B",
          "queryType": "range"
        }
      ],
      "description": "Average USD cost per request from log field `cost_usd`. Source: Loki `telemetry_event` (synthetic generator computes per-model pricing)."
    },
