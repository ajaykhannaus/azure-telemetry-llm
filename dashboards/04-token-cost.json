{
  "uid": "ai-telemetry-cost",
  "title": "4. Cost & Usage Metrics",
  "description": "Cost per request, user/session spend, daily and monthly totals, breakdowns, and cache savings.",
  "tags": [
    "ai-telemetry",
    "cost",
    "usage"
  ],
  "schemaVersion": 39,
  "version": 1,
  "style": "light",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "tenant",
        "label": "Tenant",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, tenant_id)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "model",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, model_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "environment",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, environment)",
        "multi": false,
        "includeAll": false,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "dev",
          "value": "dev"
        },
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "options": {
        "content": "<div style=\"display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:flex-start;width:100%;padding:6px 2px 2px;\"><a href=\"/d/ai-telemetry-executive\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">1. Request & Traffic</a><a href=\"/d/ai-telemetry-traffic\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">2. Traffic Analytics</a><a href=\"/d/ai-telemetry-latency\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">3. Latency</a><a href=\"/d/ai-telemetry-cost\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#1d4ed8;color:#fff;border:2px solid #1e40af;box-shadow:0 1px 3px rgba(30,64,175,.35);\">4. Cost & Usage</a><a href=\"/d/ai-telemetry-quality\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">5. Model Quality</a><a href=\"/d/ai-telemetry-safety\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">6. Safety & Security</a><a href=\"/d/ai-telemetry-infra\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">7. Infrastructure</a><a href=\"/d/ai-telemetry-tokens\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">8. Token & Context</a><a href=\"/d/ai-telemetry-users\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">9. User Observability</a></div>",
        "mode": "html"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "targets": [],
      "transparent": true
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cost per request",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg(avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap cost_usd [5m]))",
          "legendFormat": "Avg cost / request",
          "refId": "A",
          "queryType": "range"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap cost_usd [5m]))",
          "legendFormat": "{{model_name}}",
          "refId": "B",
          "queryType": "range"
        }
      ],
      "description": "Average USD cost per request from log field `cost_usd`. Source: Loki `telemetry_event` (synthetic generator computes per-model pricing)."
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cost per user/session",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "sum(sum by (user_id) (sum_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap cost_usd [5m]))) / count(sum by (user_id) (count_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" [5m])))",
          "legendFormat": "Avg spend / active user",
          "refId": "A",
          "queryType": "range"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "sum(sum by (session_id) (sum_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap cost_usd [5m]))) / count(sum by (session_id) (count_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" [5m])))",
          "legendFormat": "Avg spend / active session",
          "refId": "B",
          "queryType": "range"
        }
      ],
      "description": "Average spend per active user or session in the window \u2014 total cost \u00f7 distinct users/sessions in logs."
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Daily/monthly spend",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(increase(ai_gateway_request_cost_USD_total{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[24h]))",
          "legendFormat": "Daily spend (24h)",
          "refId": "A",
          "format": "time_series",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(increase(ai_gateway_request_cost_USD_total{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[30d]))",
          "legendFormat": "Monthly spend (30d)",
          "refId": "B",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "Total USD spent: 24h and 30d `increase` on `ai_gateway_request_cost_USD_total`."
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Total cost breakdown",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sort_desc(sum by (tenant_id) (increase(ai_gateway_request_cost_USD_total{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[24h])))",
          "legendFormat": "{{tenant_id}}",
          "refId": "A",
          "instant": true
        }
      ],
      "description": "Share of 24h spend by `tenant_id` \u2014 who is driving FinOps charges."
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Model-wise cost breakdown",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "xTickLabelRotation": -45,
        "barRadius": 0.03,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "stacking": "none",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sort_desc(sum by (model_name) (increase(ai_gateway_request_cost_USD_total{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[24h])))",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "description": "24h spend ranked by `model_name` \u2014 which models are most expensive."
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cache hit savings",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "sum(sum_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap cache_savings_usd [5m]))",
          "legendFormat": "Cache savings USD",
          "refId": "A",
          "queryType": "range"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "sum by (model_name) (sum_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap cache_savings_usd [5m]))",
          "legendFormat": "{{model_name}}",
          "refId": "B",
          "queryType": "range"
        }
      ],
      "description": "USD saved via prompt cache hits (`cache_savings_usd` in logs). Higher values mean caching is reducing billable prompt tokens."
    }
  ],
  "links": [
    {
      "asDropdown": true,
      "icon": "apps",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "ai-telemetry"
