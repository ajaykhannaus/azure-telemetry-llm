    {
      "id": 2,
      "type": "stat",
      "title": "CPU utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"ai-gateway-ns\", container=\"ai-gateway\"}[5m])) / clamp_min(sum(kube_pod_status_phase{namespace=\"ai-gateway-ns\", phase=\"Running\"}), 1) * 100",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "description": "Average CPU usage per running gateway pod: `rate(container_cpu_usage_seconds_total) / running_pod_count \u00d7 100`."
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Model throughput",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "tps",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "gridPos": {
        "x": 4,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(rate(ai_gateway_request_token_total{token_type=\"completion\",environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[5m]))",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "description": "Completion (output) tokens per second: `rate(ai_gateway_request_token_total{token_type=\"completion\"})`."
    },
    {
      "id": 4,
      "type": "stat",
      "title": "OOM failures",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "gridPos": {
        "x": 8,
        "y": 3,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(increase(kube_pod_container_oom_killed_total{namespace=\"ai-gateway-ns\"}[24h])) or vector(0)",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "description": "Container out-of-memory kills in the gateway namespace (`kube_pod_container_oom_killed_total`)."
    },
