          },
          "expr": "(sum(count_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type = \"prompt_log_event\" | pii_detected=\"true\" [24h])) / (sum(count_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type = \"prompt_log_event\" [24h])) or on() vector(1))) * 100",
          "refId": "A",
          "queryType": "range",
          "instant": false,
          "range": true
        }
      ],
      "description": "% of prompt logs with `pii_detected=true`. PII must stay in logs, not Prometheus labels."
