    {
      "id": 3,
      "type": "stat",
      "title": "Toxicity score",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "percentChangeColorMode": "standard",
        "text": {}
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg(avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"prompt_log_event\" | department=~\"$department\" | data_classification=~\"$data_class\" | model_provider=~\"$provider\" | model_name=~\"$model\" | unwrap toxicity_score [24h])) * 100",
          "refId": "A",
          "queryType": "range",
          "instant": false,
          "range": true
        }
      ],
      "description": "Average content-safety `toxicity_score` on prompt logs, scaled to 0\u2013100%. Source: Loki `prompt_log_event`."
    },
