        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg(avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | stream_response_ms > 0 | unwrap stream_response_ms [5m]))",
          "legendFormat": "Avg stream response ms",
          "refId": "A",
          "queryType": "range"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | stream_response_ms > 0 | unwrap stream_response_ms [5m]))",
          "legendFormat": "{{model_name}}",
          "refId": "B",
          "queryType": "range"
        }
      ],
