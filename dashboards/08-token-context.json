      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(rate(ai_gateway_request_token_total{token_type=\"completion\",environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[1m]))",
          "legendFormat": "Live completion tokens/s",
          "refId": "A",
          "format": "time_series",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum by (model_name) (rate(ai_gateway_request_token_total{token_type=\"completion\",environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[1m]))",
          "legendFormat": "{{model_name}}",
          "refId": "B",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "1-minute rate of completion tokens \u2014 near-real-time streaming throughput."
