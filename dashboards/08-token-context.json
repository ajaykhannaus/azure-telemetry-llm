{
  "uid": "ai-telemetry-tokens",
  "title": "8. Token & Context Metrics",
  "description": "Output tokens, per-request totals, context window fill, prompt size, streaming throughput, and error spikes.",
  "tags": [
    "ai-telemetry",
    "tokens",
    "context",
    "streaming"
  ],
  "schemaVersion": 39,
  "version": 1,
  "style": "light",
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "tenant",
        "label": "Tenant",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, tenant_id)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "model",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, model_name)",
