{
  "uid": "ai-telemetry-latency",
  "title": "3. Latency & Performance Metrics",
  "description": "End-to-end latency, percentiles, model-specific latency, first-token latency, and queue delays.",
  "tags": [
    "ai-telemetry",
    "latency",
    "performance"
  ],
  "schemaVersion": 39,
  "version": 1,
  "style": "light",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "tenant",
        "label": "Tenant",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, tenant_id)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "model",
        "label": "Model",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, model_name)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "sort": 1
      },
      {
        "type": "query",
        "name": "environment",
        "label": "Environment",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": "label_values(ai_gateway_request_count_total, environment)",
        "multi": false,
        "includeAll": false,
        "allValue": ".*",
        "hide": 0,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "dev",
          "value": "dev"
        },
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "options": {
        "content": "<div style=\"display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:flex-start;width:100%;padding:6px 2px 2px;\"><a href=\"/d/ai-telemetry-executive\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">1. Request & Traffic</a><a href=\"/d/ai-telemetry-traffic\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">2. Traffic Analytics</a><a href=\"/d/ai-telemetry-latency\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#1d4ed8;color:#fff;border:2px solid #1e40af;box-shadow:0 1px 3px rgba(30,64,175,.35);\">3. Latency</a><a href=\"/d/ai-telemetry-cost\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">4. Cost & Usage</a><a href=\"/d/ai-telemetry-quality\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">5. Model Quality</a><a href=\"/d/ai-telemetry-safety\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">6. Safety & Security</a><a href=\"/d/ai-telemetry-infra\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">7. Infrastructure</a><a href=\"/d/ai-telemetry-tokens\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">8. Token & Context</a><a href=\"/d/ai-telemetry-users\" style=\"display:inline-flex;align-items:center;padding:9px 14px;margin:0;border-radius:8px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;letter-spacing:.01em;background:#eff6ff;color:#1e3a8a;border:1px solid #93c5fd;\">9. User Observability</a></div>",
        "mode": "html"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "targets": [],
      "transparent": true
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "End-to-end response latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(rate(ai_gateway_request_duration_milliseconds_sum{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[5m])) / clamp_min(sum(rate(ai_gateway_request_duration_milliseconds_count{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[5m])), 1e-9)",
          "legendFormat": "Avg latency",
          "refId": "A",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "Average gateway response time in ms: histogram `_sum / _count` on `ai_gateway_request_duration_milliseconds`. Includes queue, model, and streaming time."
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Latency \u2014 p50 / p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ai_gateway_request_duration_milliseconds_bucket{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A",
          "format": "time_series",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ai_gateway_request_duration_milliseconds_bucket{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B",
          "format": "time_series",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ai_gateway_request_duration_milliseconds_bucket{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "Latency percentiles from the request duration histogram. p99 is the slowest 1% \u2014 the usual SLO pain metric."
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Model Specific Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.95, sum by (le, model_name) (rate(ai_gateway_request_duration_milliseconds_bucket{environment=~\"$environment\",tenant_id=~\"$tenant\",model_name=~\"$model\"}[5m])))",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "p95 end-to-end latency per `model_name`. Compares which models are consistently slower."
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "First token latency (Model Based)",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | streaming=\"true\" | unwrap first_token_ms [5m]))",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "description": "Average `first_token_ms` for streaming requests, by model. Source: Loki logs \u2014 time until the first token is returned to the client."
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queue delays",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg(avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap queue_wait_ms [5m]))",
          "legendFormat": "Avg queue delay",
          "refId": "A",
          "queryType": "range"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | tenant_id=~\"$tenant\" | model_name=~\"$model\" | unwrap queue_wait_ms [5m]))",
          "legendFormat": "{{model_name}}",
          "refId": "B",
          "queryType": "range"
        }
      ],
      "description": "Average `queue_wait_ms` before the model starts processing. Source: Loki \u2014 separates queue congestion from model inference time."
    }
  ],
  "links": [
    {
      "asDropdown": true,
      "icon": "apps",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "ai-telemetry"
      ],
      "title": "All dashboards",
      "tooltip": "Jump to any AI Telemetry dashboard",
      "type": "dashboards",
      "targetBlank": false
    }
  ]
}