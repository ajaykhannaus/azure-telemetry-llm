              "viz": false
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.95, sum by (le, model_name) (rate(ai_gateway_request_duration_milliseconds_bucket{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",operation_name=~\"$operation\",environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "p95 end-to-end latency per `model_name`. Compares which models are consistently slower."
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "First token latency (Model Based)",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "showPoints": "never",
            "pointSize": 5,
            "axisColorMode": "text",
            "axisBorderShow": false,
            "axisGridShow": true,
            "lineStyle": {
              "fill": "solid"
            },
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "avg by (model_name) (avg_over_time({service_name=~\".+\"} | json | line_format \"{{.body}}\" | json | event_type=\"telemetry_event\" | department=~\"$department\" | region=~\"$region\" | model_provider=~\"$provider\" | model_name=~\"$model\" | operation_name=~\"$operation\" | first_token_ms > 0 | unwrap first_token_ms [5m]))",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "description": "Average `first_token_ms` for streaming requests, by model. Source: Loki logs \u2014 time until the first token is returned to the client."
    },
