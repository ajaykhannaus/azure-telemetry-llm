            },
            "showPoints": "never",
            "pointSize": 5,
            "axisColorMode": "text",
            "axisBorderShow": false,
            "axisGridShow": true,
            "lineStyle": {
              "fill": "solid"
            },
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
