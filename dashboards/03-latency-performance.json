    {
      "id": 3,
      "type": "timeseries",
      "title": "End-to-end response latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "showPoints": "never",
            "pointSize": 5,
            "axisColorMode": "text",
            "axisBorderShow": false,
            "axisGridShow": true,
            "lineStyle": {
              "fill": "solid"
            },
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(rate(ai_gateway_request_duration_milliseconds_sum{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",operation_name=~\"$operation\",environment=~\"$environment\"}[5m])) / clamp_min(sum(rate(ai_gateway_request_duration_milliseconds_count{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",operation_name=~\"$operation\",environment=~\"$environment\"}[5m])), 1e-9)",
          "legendFormat": "Avg latency",
          "refId": "A",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "Average gateway response time in ms: histogram `_sum / _count` on `ai_gateway_request_duration_milliseconds`. Includes queue, model, and streaming time."
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Latency \u2014 p50 / p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "showPoints": "never",
            "pointSize": 5,
            "axisColorMode": "text",
            "axisBorderShow": false,
            "axisGridShow": true,
            "lineStyle": {
              "fill": "solid"
            },
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ai_gateway_request_duration_milliseconds_bucket{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",operation_name=~\"$operation\",environment=~\"$environment\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A",
          "format": "time_series",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ai_gateway_request_duration_milliseconds_bucket{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",operation_name=~\"$operation\",environment=~\"$environment\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B",
          "format": "time_series",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ai_gateway_request_duration_milliseconds_bucket{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",operation_name=~\"$operation\",environment=~\"$environment\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "Latency percentiles from the request duration histogram. p99 is the slowest 1% \u2014 the usual SLO pain metric."
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Model Specific Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
