      "gridPos": {
        "x": 8,
        "y": 7,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-ds"
          },
          "expr": "count(count by (user_id) (count_over_time({service_name=~\".+\"} | json | event_type=\"telemetry_event\" | department=~\"$department\" | region=~\"$region\" | model_provider=~\"$provider\" | model_name=~\"$model\" | user_id != \"\" [5m])))",
          "refId": "A",
          "queryType": "range",
          "instant": false,
          "range": true
        }
      ],
      "description": "Distinct active users in the last 5 minutes (last value). Source: Loki `telemetry_event` logs."
