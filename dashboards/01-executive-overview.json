    {
      "id": 3,
      "type": "stat",
      "title": "Total requests",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true,
        "showPercentChange": false,
        "percentChangeColorMode": "standard",
        "text": {}
      },
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum(increase(ai_gateway_request_count_total{department=~\"$department\",region=~\"$region\",model_provider=~\"$provider\",model_name=~\"$model\",environment=~\"$environment\"}[$__range]))",
          "refId": "A",
          "range": true,
          "instant": false
        }
      ],
      "description": "Single headline count for the selected time range with a sparkline trend. Source: Prometheus `increase(ai_gateway_request_count_total[$__range])`."
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active users",
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
