    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests / min by Model",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "r/min",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "stacking": {
              "mode": "none"
            },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "expr": "sum by (model_name) (rate(ai_gateway_request_count_total{tenant_id=~\"$tenant\"}[2m])) * 60",
          "legendFormat": "{{model_name}}",
          "refId": "A",
          "format": "time_series",
          "range": true
        }
      ],
      "description": "Live request rate per model (`rate \u00d7 60`). Filtered by tenant template variable when set."
    },
